    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "1.50.1",
    "express": "5.2.1",
    "multer": "2.1.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "fast-check": "4.7.0",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
