{
  "name": "image-qa-app",
  "version": "1.0.0",
  "description": "Upload an image and ask a natural-language question powered by Gemini",
  "main": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
